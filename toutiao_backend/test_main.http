### root
GET http://127.0.0.1:8000/

### register
POST http://127.0.0.1:8000/api/user/register
Content-Type: application/json

{
  "username": "test_user",
  "password": "123456"
}

### login
POST http://127.0.0.1:8000/api/user/login
Content-Type: application/json

{
  "username": "test_user",
  "password": "123456"
}

### categories
GET http://127.0.0.1:8000/api/news/categories

### news list
GET http://127.0.0.1:8000/api/news/list?categoryId=1&page=1&pageSize=10

### news detail
GET http://127.0.0.1:8000/api/news/detail?id=1

### favorite check
GET http://127.0.0.1:8000/api/favorite/check?newsId=1
Authorization: Bearer {{token}}

### favorite add
POST http://127.0.0.1:8000/api/favorite/add
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "newsId": 1
}

### favorite remove
DELETE http://127.0.0.1:8000/api/favorite/remove?newsId=1
Authorization: Bearer {{token}}

### favorite list
GET http://127.0.0.1:8000/api/favorite/list?page=1&pageSize=10
Authorization: Bearer {{token}}

### favorite clear
DELETE http://127.0.0.1:8000/api/favorite/clear
Authorization: Bearer {{token}}

### history add
POST http://127.0.0.1:8000/api/history/add
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "newsId": 1
}

### history list
GET http://127.0.0.1:8000/api/history/list?page=1&pageSize=10
Authorization: Bearer {{token}}

### history delete
DELETE http://127.0.0.1:8000/api/history/delete/1
Authorization: Bearer {{token}}

### history clear
DELETE http://127.0.0.1:8000/api/history/clear
Authorization: Bearer {{token}}
