{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FastAPI: Start Uvicorn",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "uvicorn",
        "toutiao_backend.main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
